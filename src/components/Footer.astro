---
import { COMPLIANCE, TAGLINE, BOOKING_URL, NAV_LINKS } from '../site.config';
const year = 2026;

interface Props {
  showResetProgress?: boolean;
}
const { showResetProgress = false } = Astro.props;
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/brand/psg-logo-nav.png" alt="Price Services Group logo" width="200" height="101" loading="lazy" decoding="async" />
        <p class="tagline">{TAGLINE}</p>
      </div>
      <nav class="footer-links">
        {NAV_LINKS.filter((l) => l.href !== '/').map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>
      <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="btn btn-teal">Schedule Free Review</a>
    </div>

    <div class="compliance">
      <p>{COMPLIANCE.npn} &bull; {COMPLIANCE.agencyNpn}</p>
      <p>Licensed in: {COMPLIANCE.states.join(', ')}</p>
      <p class="tpmo">{COMPLIANCE.tpmo}</p>
      <p class="legal-links">
        <a href="/privacy">Privacy Policy</a> &bull; <a href="/terms">Terms of Use</a>
        {showResetProgress && (
          <>
            &bull; <button type="button" id="reset-progress-link" class="reset-progress-link">Reset Progress</button>
          </>
        )}
      </p>
      <p class="copyright">&copy; {year} Price Services Group LLC. {TAGLINE}</p>
    </div>

    <div class="tpmo-disclaimer">
      <p>We do not offer every plan available in your area. Please contact Medicare.gov, 1-800-MEDICARE, or your local State Health Insurance Program (SHIP) to get information on all of your options.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark);
    color: #e7dcf4;
    padding: 3.5rem 0 2rem;
    margin-top: 3rem;
  }
  .footer-inner { display: flex; flex-direction: column; gap: 2rem; }
  .footer-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .footer-brand img { height: 34px; margin-bottom: 0.4rem; }
  .tagline { font-family: var(--font-heading); font-style: italic; color: var(--color-teal); margin: 0; }
  .footer-links { display: flex; flex-wrap: wrap; gap: 1rem 1.5rem; }
  .footer-links a { color: #d8c8ea; text-decoration: none; font-size: 0.9rem; }
  .footer-links a:hover { color: var(--color-teal); }
  .compliance p {
    font-size: 0.78rem;
    line-height: 1.6;
    color: #b6a4cb;
    max-width: 900px;
    margin: 0 0 0.5rem;
  }
  .copyright { color: #9e8bb6; }
  .legal-links { }
  .legal-links a { color: #b6a4cb; text-decoration: underline; }
  .legal-links a:hover { color: var(--color-teal); }
  .tpmo-disclaimer {
    max-width: 900px;
    margin: 0.5rem auto 0;
    text-align: center;
  }
  .tpmo-disclaimer p {
    font-family: 'Open Sans', sans-serif;
    font-size: 12px;
    color: #b6a4cb;
    margin: 0;
  }
  .reset-progress-link {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: #b6a4cb;
    text-decoration: underline;
    cursor: pointer;
  }
  .reset-progress-link:hover {
    color: var(--color-teal);
  }
</style>

{showResetProgress && (
  <script>
    import { resetProgress } from '../scripts/course-progress';

    document.getElementById('reset-progress-link')?.addEventListener('click', () => {
      if (window.confirm('Reset your course progress? This clears completed/started status for all lessons on this device.')) {
        resetProgress();
        window.location.reload();
      }
    });
  </script>
)}
