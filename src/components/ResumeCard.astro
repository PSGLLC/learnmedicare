---
// Feature 8 — homepage "resume where you left off" card. Hidden entirely
// (via [hidden] + JS toggle) for first-time visitors with no stored
// progress; populated client-side from the same localStorage module used
// on the lesson pages, so it works whether the visitor last hit /basics,
// /course, or any other tracked lesson.
---
<section class="resume-card-section" id="resume-card-section" hidden>
  <div class="container">
    <div class="resume-card">
      <p class="resume-eyebrow">Welcome back!</p>
      <p class="resume-text">You left off at <strong id="resume-lesson-name">a lesson</strong>.</p>
      <a href="/basics" id="resume-continue-link" class="btn btn-primary">Continue &rarr;</a>
    </div>
  </div>
</section>

<style>
  .resume-card-section {
    padding: 1.5rem 0 0;
  }
  .resume-card {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius, 10px);
    background: var(--color-lavender);
    border: 1px solid var(--color-border);
  }
  :root[data-theme="dark"] .resume-card {
    background: rgba(144, 89, 181, 0.12);
  }
  .resume-eyebrow {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-purple);
  }
  .resume-text {
    margin: 0.2rem 0 0;
    flex: 1 1 260px;
  }
</style>

<script>
  import { getLastLesson, hasAnyProgress } from '../scripts/course-progress';

  const section = document.getElementById('resume-card-section');
  const nameEl = document.getElementById('resume-lesson-name');
  const link = document.getElementById('resume-continue-link') as HTMLAnchorElement | null;

  if (section && hasAnyProgress()) {
    const last = getLastLesson();
    if (last) {
      if (nameEl) nameEl.textContent = last.label;
      if (link) link.href = last.path;
      section.hidden = false;
    }
  }
</script>
