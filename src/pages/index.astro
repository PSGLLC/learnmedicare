---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResumeCard from '../components/ResumeCard.astro';
import { BOOKING_URL } from '../site.config';
import { authorship, dataset } from '../lib/schema';

const DATE_PUBLISHED = '2026-07-23';
const DATE_MODIFIED = '2026-07-24';

const lessons = [
  { n: 1, title: 'Medicare Options Overview', desc: 'A bird\'s-eye view of how Medicare fits together.' },
  { n: 2, title: 'Original Medicare Parts A & B', desc: 'Hospital and medical coverage, explained simply.' },
  { n: 3, title: 'Medicare Advantage', desc: 'How private Part C plans work.' },
  { n: 4, title: 'Medicare Supplement / Medigap', desc: 'Filling the gaps in Original Medicare.' },
  { n: 5, title: 'Part D Prescription Drugs', desc: 'Understanding drug coverage and formularies.' },
  { n: 6, title: 'Your Next Step', desc: 'How to move from learning to enrolling with confidence.' },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Learn Medicare — Free Medicare Education',
    description: 'Free, unbiased Medicare education. Understand your options before you enroll.',
    url: 'https://learnmedicare.org/',
    ...authorship(DATE_PUBLISHED, DATE_MODIFIED),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is Medicare?',
        acceptedAnswer: { '@type': 'Answer', text: 'Medicare is the federal health insurance program run by the Centers for Medicare & Medicaid Services (CMS), primarily covering people 65 and older and certain younger people with qualifying disabilities.' },
      },
      {
        '@type': 'Question',
        name: 'Is this free Medicare course really free?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. The six-lesson course, guides, and calculators on this site are free to use, with no obligation to purchase any insurance product.' },
      },
      {
        '@type': 'Question',
        name: 'Is Learn Medicare an official government resource?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. Learn Medicare is independent educational content produced by a licensed insurance agency, not an official Medicare or government website. For official guidance, visit Medicare.gov or call 1-800-MEDICARE.' },
      },
    ],
  },
  dataset({
    name: 'Medicare Part B Standard Premium 2026',
    description: 'The standard monthly Medicare Part B premium and annual deductible for 2026, as published by CMS.',
    creatorUrl: 'https://www.medicare.gov/basics/costs/medicare-costs',
  }),
  {
    '@context': 'https://schema.org',
    '@type': 'EducationalOrganization',
    name: 'Learn Medicare',
    url: 'https://learnmedicare.org',
    description: 'Free, unbiased Medicare education from a licensed independent agent.',
    logo: 'https://learnmedicare.org/brand/psg-logo.png',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'LearnMedicare.org',
    url: 'https://learnmedicare.org',
    logo: 'https://learnmedicare.org/favicon.ico',
    description: 'Free Medicare education resource helping people understand their options before talking to an agent.',
    sameAs: ['https://priceservicesgroup.com'],
    parentOrganization: {
      '@type': 'Organization',
      name: 'Price Services Group, LLC',
      url: 'https://priceservicesgroup.com',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '866-648-1578',
      contactType: 'customer service',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SpeakableSpecification',
    cssSelector: ['.hero-inner h1', '.hero-inner .subhead'],
  },
];
---
<BaseLayout
  title="Learn Medicare — Free Medicare Education | Where You Matter"
  description="Free, unbiased Medicare education. Understand your options before you enroll. No pressure, no sales pitch."
  path="/"
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Free Medicare Education</p>
      <h1>Free Medicare Education — Where You Matter</h1>
      <p class="subhead">Understand your options before you enroll. No pressure, no sales pitch.</p>
      <a href="/basics" class="btn btn-primary">Start Learning Free</a>
    </div>
  </section>

  <ResumeCard />

  <section>
    <div class="container">
      <p class="eyebrow">Free Mini-Course</p>
      <h2>Six short lessons. Zero sales pitch.</h2>
      <div class="grid grid-3">
        {lessons.map((l) => (
          <a href="/course" class="card lesson-card">
            <span class="lesson-num">Lesson {l.n}</span>
            <h3>{l.title}</h3>
            <p>{l.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-alt">
    <div class="container meet-kayla">
      <img src="/img/headshot.png" alt="Kayla, licensed independent Medicare agent" class="headshot" width="1024" height="1024" loading="lazy" decoding="async" />
      <div class="card kayla-card">
        <p class="eyebrow">Meet Kayla</p>
        <h2>Your guide through Medicare</h2>
        <p>
          Kayla is a licensed independent Medicare agent (NPN 18530055) dedicated to helping
          people understand their coverage options in plain English, without pressure or a sales pitch.
          Because she isn't tied to a single insurance company, her focus stays on your questions —
          not a quota.
        </p>
        <p>
          Whether you're new to Medicare or reviewing your current plan, Kayla believes informed
          decisions start with clear, honest education — because where you matter, you deserve real answers.
        </p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Ready for personalized guidance?</h2>
      <p>Schedule a free, no-pressure review with a licensed independent agent.</p>
      <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="btn btn-teal">Schedule Free Review</a>
    </div>
  </section>

  <section class="section-alt">
    <div class="container quiz-inner">
      <p class="eyebrow">Free Quiz</p>
      <h2>What's Your Medicare Decision Style?</h2>
      <p class="quiz-sub">Answer a few quick questions and get a sense of how you tend to approach Medicare decisions.</p>
      <a href="https://partner.priceservicesgroup.com/quiz" class="btn btn-primary">Take the Free Quiz →</a>
    </div>
  </section>

  <section class="lead-section">
    <div class="container lead-inner">
      <div class="lead-copy">
        <p class="eyebrow">Free Guide</p>
        <h2>Get Your Free Medicare Guide</h2>
        <p class="subhead">
          Tell us a little about yourself and we'll send you the right guide for your situation.
        </p>
      </div>

      <form id="lead-form" class="lead-form" novalidate>
        <div class="form-row">
          <label for="lead-firstName">First Name <span aria-hidden="true">*</span></label>
          <input type="text" id="lead-firstName" name="firstName" autocomplete="given-name" required />
        </div>
        <div class="form-row">
          <label for="lead-lastName">Last Name <span aria-hidden="true">*</span></label>
          <input type="text" id="lead-lastName" name="lastName" autocomplete="family-name" required />
        </div>
        <div class="form-row">
          <label for="lead-email">Email <span aria-hidden="true">*</span></label>
          <input type="email" id="lead-email" name="email" autocomplete="email" required />
        </div>
        <div class="form-row">
          <label for="lead-phone">Phone <span class="optional">(optional)</span></label>
          <input type="tel" id="lead-phone" name="phone" autocomplete="tel" />
        </div>
        <div class="form-row">
          <label for="lead-status">Which best describes you? <span aria-hidden="true">*</span></label>
          <select id="lead-status" name="status" required>
            <option value="" disabled selected>Select one</option>
            <option value="turning-65">Turning 65</option>
            <option value="new-to-medicare">New to Medicare</option>
            <option value="already-on-medicare">Already on Medicare</option>
            <option value="just-exploring">Just Exploring</option>
          </select>
        </div>

        <!-- Honeypot — hidden from real visitors -->
        <div class="hp-field" aria-hidden="true">
          <label for="lead-website">Website</label>
          <input type="text" id="lead-website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="form-row form-row-checkbox">
          <label class="checkbox-label" for="lead-tcpaConsent">
            <input type="checkbox" id="lead-tcpaConsent" name="tcpaConsent" required />
            <span>
              By submitting this form, I consent to be contacted by Price Services Group and its
              licensed agents by phone (including autodialed calls), text message, and email
              regarding Medicare plan options. I understand I can revoke this consent at any time
              by replying STOP to texts or contacting us directly. Message and data rates may
              apply.
            </span>
          </label>
        </div>

        <button type="submit" class="btn btn-primary form-submit">Get My Free Guide</button>
        <p id="lead-form-error" class="form-error" role="alert" hidden></p>
      </form>

      <div id="lead-form-success" class="form-success" hidden>
        <p>Thank you! Check your email for your free guide.</p>
      </div>

      <p class="compliance-note">
        By submitting this form you agree to be contacted by Price Services Group LLC.
        We respect your privacy and will never sell your information.
      </p>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      <p class="eyebrow">Free Resources</p>
      <h2>Free Medicare Guides</h2>
      <div class="grid grid-3">
        <div class="card guide-card">
          <h3>Turning 65 Guide</h3>
          <p>Everything you need to know before Medicare begins.</p>
          <a href="https://partner.priceservicesgroup.com/guides/t65-medicare-guide" class="btn btn-teal">Download Free Guide →</a>
        </div>
        <div class="card guide-card">
          <h3>New to Medicare Guide</h3>
          <p>Just enrolled? Here's how to use your benefits.</p>
          <a href="https://partner.priceservicesgroup.com/guides/new-to-medicare-guide" class="btn btn-teal">Download Free Guide →</a>
        </div>
        <div class="card guide-card">
          <h3>Already on Medicare Guide</h3>
          <p>Make sure your coverage is still working for you.</p>
          <a href="https://partner.priceservicesgroup.com/guides/already-on-medicare-guide" class="btn btn-teal">Download Free Guide →</a>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('lead-form') as HTMLFormElement | null;
    const errorEl = document.getElementById('lead-form-error');
    const successEl = document.getElementById('lead-form-success');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (errorEl) {
        errorEl.hidden = true;
        errorEl.textContent = '';
      }

      const formData = new FormData(form);
      const tcpaConsent = formData.get('tcpaConsent') === 'on';

      if (!tcpaConsent) {
        if (errorEl) {
          errorEl.textContent = 'Please check the box to agree to be contacted.';
          errorEl.hidden = false;
        }
        return;
      }

      const payload = {
        first_name: String(formData.get('firstName') ?? '').trim(),
        last_name: String(formData.get('lastName') ?? '').trim(),
        email: String(formData.get('email') ?? '').trim(),
        phone: String(formData.get('phone') ?? '').trim(),
        status: String(formData.get('status') ?? '').trim(),
        website: String(formData.get('website') ?? ''),
        tcpaConsent: true,
        pagePath: window.location.pathname,
      };

      const submitBtn = form.querySelector<HTMLButtonElement>('.form-submit');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';
      }

      try {
        const res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({ ok: false }));

        if (res.ok && data.ok) {
          form.hidden = true;
          if (successEl) successEl.hidden = false;
        } else {
          throw new Error(data.error || 'Something went wrong. Please try again.');
        }
      } catch (err) {
        if (errorEl) {
          errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
          errorEl.hidden = false;
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Get My Free Guide';
        }
      }
    });
  </script>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-dark) 0%, #2b1147 100%);
    color: #fff;
    padding: 6rem 0;
  }
  .hero-inner { max-width: 700px; }
  .hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3.2rem); }
  .hero .eyebrow { color: var(--color-teal); }
  .subhead { font-size: 1.15rem; color: #e2d4f0; margin-bottom: 1.75rem; }

  .lesson-card { text-decoration: none; display: block; transition: transform 0.15s ease; }
  .lesson-card:hover { transform: translateY(-4px); }
  .lesson-num {
    display: inline-block;
    background: var(--color-lavender);
    color: var(--color-purple);
    font-weight: 700;
    font-size: 0.75rem;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }
  :root[data-theme="dark"] .lesson-num { background: rgba(81,222,204,0.15); color: var(--color-teal); }
  .lesson-card h3 { font-size: 1.1rem; margin-bottom: 0.4rem; }
  .lesson-card p { color: var(--color-text-muted); font-size: 0.92rem; margin: 0; }

  .meet-kayla {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .headshot {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  .kayla-card p:last-child { margin-bottom: 0; }
  @media (max-width: 800px) {
    .meet-kayla { grid-template-columns: 1fr; }
    .headshot { max-width: 260px; margin: 0 auto; }
  }

  .cta-section {
    background: var(--color-purple);
    color: #fff;
    text-align: center;
  }
  .cta-inner h2 { color: #fff; }
  .cta-inner p { color: #f0e6f8; margin-bottom: 1.5rem; }

  .quiz-inner { text-align: center; max-width: 640px; }
  .quiz-sub { color: var(--color-text-muted); margin-bottom: 1.5rem; }

  .lead-section { padding: 4rem 0; }
  .lead-inner { max-width: 640px; margin: 0 auto; text-align: center; }
  .lead-copy .subhead { color: var(--color-text-muted); margin-bottom: 1.5rem; }
  .lead-form { display: flex; flex-direction: column; gap: 1rem; text-align: left; }
  .form-row { display: flex; flex-direction: column; gap: 0.35rem; }
  .form-row label { font-weight: 600; font-size: 0.9rem; color: var(--color-text); }
  .form-row .optional { font-weight: 400; color: var(--color-text-muted); font-size: 0.8rem; }
  .form-row input,
  .form-row select {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.7rem 0.9rem;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
  }
  .form-row input:focus,
  .form-row select:focus {
    outline: none;
    border-color: var(--color-purple);
    box-shadow: 0 0 0 3px rgba(144, 89, 181, 0.18);
  }
  :root[data-theme="dark"] .form-row input:focus,
  :root[data-theme="dark"] .form-row select:focus {
    border-color: var(--color-teal);
    box-shadow: 0 0 0 3px rgba(81, 222, 204, 0.18);
  }
  .hp-field { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .form-row-checkbox { flex-direction: row; }
  .checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    cursor: pointer;
  }
  .checkbox-label input[type='checkbox'] {
    flex-shrink: 0;
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.15rem;
    accent-color: var(--color-purple);
  }
  .form-submit { width: 100%; text-align: center; margin-top: 0.25rem; }
  .form-submit:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
  .form-error { color: #b3261e; font-size: 0.9rem; margin: 0; }
  .form-success {
    background: var(--color-lavender);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-align: center;
    font-weight: 600;
    color: var(--color-text);
  }
  :root[data-theme="dark"] .form-success { background: rgba(81, 222, 204, 0.12); }
  .guide-card { text-align: center; }
  .guide-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .guide-card p { color: var(--color-text-muted); font-size: 0.92rem; margin-bottom: 1.25rem; }
  .guide-card .btn { width: 100%; text-align: center; }

  .compliance-note {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    margin: 1.25rem 0 0;
    text-align: center;
  }
</style>
