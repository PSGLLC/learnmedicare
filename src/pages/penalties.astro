---
import BaseLayout from '../layouts/BaseLayout.astro';
import MarkCompleteButton from '../components/MarkCompleteButton.astro';
import { authorship, dataset } from '../lib/schema';

const DATE_PUBLISHED = '2026-07-23';
const DATE_MODIFIED = '2026-07-24';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Medicare Late Enrollment Penalties',
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.quick-answer'],
    },
    ...authorship(DATE_PUBLISHED, DATE_MODIFIED),
  },
  dataset({
    name: 'Medicare Part B & Part D Late Enrollment Penalty Rates',
    description: 'Official CMS formulas for Medicare Part B (10% per 12-month period) and Part D (1% of national base beneficiary premium per month) late enrollment penalties.',
    creatorUrl: 'https://www.medicare.gov/basics/costs/medicare-costs',
  }),
  {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  author: { '@type': 'Person', name: 'Kayla Price', url: 'https://priceservicesgroup.com' },
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How is the Medicare Part B late enrollment penalty calculated?',
      acceptedAnswer: { '@type': 'Answer', text: 'For each full 12-month period you were eligible for Part B but didn\'t enroll (and didn\'t have other creditable coverage), your monthly premium may go up by roughly 10%. This penalty generally lasts as long as you have Part B.' },
    },
    {
      '@type': 'Question',
      name: 'How is the Medicare Part D late enrollment penalty calculated?',
      acceptedAnswer: { '@type': 'Answer', text: 'The Part D penalty is generally about 1% of the national base beneficiary premium for each full month you went without creditable prescription drug coverage, added to your monthly Part D premium for as long as you have Part D coverage.' },
    },
    {
      '@type': 'Question',
      name: 'How can I avoid the Medicare late enrollment penalties?',
      acceptedAnswer: { '@type': 'Answer', text: 'Enroll during your Initial Enrollment Period, or make sure any coverage you keep instead (such as employer coverage) qualifies as creditable coverage so you avoid a penalty when you do eventually sign up.' },
    },
    {
      '@type': 'Question',
      name: 'Do the Part B and Part D penalties ever go away?',
      acceptedAnswer: { '@type': 'Answer', text: 'Generally, no. Both penalties are typically added to your premium for as long as you have that part of Medicare, which is why enrolling on time or maintaining creditable coverage matters.' },
    },
    ],
  },
];
---
<BaseLayout
  title="Medicare Late Enrollment Penalties: Part B & Part D Explained | Learn Medicare"
  description="How Medicare Part B and Part D late enrollment penalties are calculated, with illustrative examples. Educational content only."
  path="/penalties/"
  breadcrumbs={[{ name: 'Penalties', url: '/penalties/' }]}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Penalties</p>
      <h1>Understanding Medicare late enrollment penalties</h1>
      <p class="subhead">Enrolling late without other qualifying coverage can add a lasting penalty to your premiums. Here's how the math works.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="quick-answer">
        <p class="quick-answer-label">Quick Answer</p>
        <p>
          The Medicare Part B late enrollment penalty is 10% of the standard premium for each
          12-month period you went without coverage. The Part D late enrollment penalty is 1% of
          the national base beneficiary premium per month without coverage. Both penalties last as
          long as you have Medicare.
        </p>
      </div>

      <div class="grid grid-2">
        <div class="card">
          <h2>Part B Late Enrollment Penalty</h2>
          <p>
            For each full 12-month period you were eligible for Part B but didn't sign up during your
            <a href="/enrollment">Initial Enrollment Period</a> — and didn't have other creditable
            coverage, such as through an employer — your monthly Part B premium can increase by
            roughly <strong>10%</strong>. This higher premium generally applies for as long as you
            have Part B.
          </p>
          <div class="example">
            <strong>Illustrative example:</strong> If you delayed Part B by 24 months (two full
            12-month periods) without creditable coverage, your premium could increase by roughly
            20% for as long as you have Part B. This is a hypothetical example to illustrate the
            formula, not a current rate.
          </div>
        </div>
        <div class="card">
          <h2>Part D Late Enrollment Penalty</h2>
          <p>
            The Part D penalty is generally about <strong>1% of the national base beneficiary
            premium</strong> for each full month you went without Part D or other creditable
            prescription drug coverage after becoming eligible. That amount is added to your monthly
            Part D premium for as long as you have Part D coverage.
          </p>
          <div class="example">
            <strong>Illustrative example:</strong> If you went 18 months without creditable drug
            coverage, your penalty could be roughly 18% of that year's national base beneficiary
            premium, added to your monthly Part D premium. This is a hypothetical example to
            illustrate the formula, not a current rate.
          </div>
        </div>
      </div>

      <div class="callout" style="margin-top: 2.5rem;">
        <p style="margin:0;">
          <strong>The best way to avoid these penalties:</strong> enroll during your Initial
          Enrollment Period, or make sure any coverage you have while delaying Medicare qualifies as
          "creditable coverage." See <a href="/working-at-65">Working at 65</a> to learn more about
          creditable coverage. Official penalty rules are published at
          <a href="https://www.medicare.gov/basics/costs/medicare-costs" target="_blank" rel="noopener noreferrer">Medicare.gov</a>.
        </p>
      </div>
    </div>
  </section>

  <p style="text-align:center;color:var(--color-text-muted);font-size:.95rem;max-width:640px;margin:0 auto 2rem;">
    Not sure how these penalties apply to your situation? <a href="https://partner.priceservicesgroup.com/quiz">Take the Medicare Decision Style Quiz</a> or
    <a href="https://priceservicesgroup.com/contact">schedule a consultation with a Medicare advisor</a>.
  </p>

  <MarkCompleteButton slug="penalties" />

  <section class="section-alt cta-band">
    <div class="container cta-inner">
      <h2>Still working? Here's what to know</h2>
      <p>Learn how Medicare interacts with employer coverage after 65.</p>
      <a href="/working-at-65" class="btn btn-primary">Continue to Working at 65</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { background: var(--color-lavender); padding: 4rem 0; }
  :root[data-theme="dark"] .page-hero { background: var(--color-bg-alt); }
  .subhead { color: var(--color-text-muted); font-size: 1.1rem; max-width: 680px; }
  .example {
    margin-top: 1rem;
    padding: 1rem;
    background: var(--color-bg-alt);
    border-radius: 10px;
    font-size: 0.92rem;
    border: 1px solid var(--color-border);
  }
  .cta-band { text-align: center; }
  .cta-inner p { color: var(--color-text-muted); margin-bottom: 1.5rem; }

  .quick-answer {
    border-left: 4px solid var(--color-purple);
    background: var(--color-lavender);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }
  :root[data-theme="dark"] .quick-answer {
    background: rgba(144, 89, 181, 0.1);
  }
  .quick-answer-label {
    margin: 0 0 0.4rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-purple);
  }
  .quick-answer p:last-child { margin: 0; }
</style>
