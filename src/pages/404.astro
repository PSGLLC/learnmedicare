---
import BaseLayout from '../layouts/BaseLayout.astro';

Astro.response.status = 404;
Astro.response.statusText = 'Not Found';
---

<BaseLayout
  title="Page Not Found | Learn Medicare"
  description="The page you're looking for doesn't exist. Explore our Medicare guides on enrollment, coverage, and penalties instead."
  path="/404/"
>
  <section class="not-found">
    <h1>404 — Page Not Found</h1>
    <p>Sorry, we couldn't find the page you were looking for.</p>
    <p><a href="/">Return to the homepage</a> or check out our <a href="/guide/">free Medicare guide</a>.</p>
  </section>
</BaseLayout>

<style>
  .not-found {
    max-width: 640px;
    margin: 4rem auto;
    padding: 0 1.5rem;
    text-align: center;
  }
</style>
