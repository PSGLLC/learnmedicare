---
import MinimalLayout from '../layouts/MinimalLayout.astro';
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What does the free Medicare course teach?',
      acceptedAnswer: { '@type': 'Answer', text: 'The course covers everything you need to know before you enroll in Medicare, broken into six self-paced lessons.' },
    },
    {
      '@type': 'Question',
      name: 'Is the Medicare course really free?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes, the course is completely free to take, with no obligation to purchase any insurance plan.' },
    },
    {
      '@type': 'Question',
      name: 'How long does the course take to complete?',
      acceptedAnswer: { '@type': 'Answer', text: 'It\'s self-paced, so you can go through the six lessons on your own schedule and revisit them any time.' },
    },
    {
      '@type': 'Question',
      name: 'Do I need to create an account to take the course?',
      acceptedAnswer: { '@type': 'Answer', text: 'No account is required — the course loads directly on this page, or you can watch it at course.learnmedicare.org.' },
    },
    {
      '@type': 'Question',
      name: 'Is this official Medicare guidance?',
      acceptedAnswer: { '@type': 'Answer', text: 'No. This is independent educational content from a licensed insurance agency, not an official Medicare or government resource. For official guidance, always confirm details at Medicare.gov or 1-800-MEDICARE.' },
    },
  ],
};

const courseJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Medicare Made Simple — Free Online Medicare Education Course',
  url: 'https://learnmedicare.org',
  description:
    'A free, self-paced course covering Medicare basics, Part A, Part B, Part D, Medicare Advantage, Medigap, and enrollment periods — built for people approaching or navigating Medicare enrollment.',
  provider: {
    '@type': 'Organization',
    name: 'Price Services Group, LLC',
    url: 'https://priceservicesgroup.com',
    sameAs: 'https://priceservicesgroup.com',
  },
  instructor: {
    '@type': 'Person',
    name: 'Kayla Price',
    hasCredential: {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Licensed Insurance Agent',
      identifier: 'NPN 18530055',
    },
  },
  isAccessibleForFree: true,
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
    courseWorkload: 'PT1H',
  },
};

const jsonLd = [faqJsonLd, courseJsonLd];
const LESSONS = [
  { n: 1, title: 'Medicare Basics' },
  { n: 2, title: 'Enrollment Periods' },
  { n: 3, title: 'Coverage Options' },
  { n: 4, title: 'Avoiding Penalties' },
  { n: 5, title: 'Working Past 65' },
  { n: 6, title: 'Putting It All Together' },
];
---
<MinimalLayout
  title="Free Medicare Course | Learn Medicare"
  description="Take our free, self-paced Medicare course — six lessons covering everything you need to know before you enroll."
  path="/course/"
  breadcrumbs={[{ name: 'Take the Course', url: '/course/' }]}
  jsonLd={jsonLd}
>
  <section class="course-hero">
    <div class="container">
      <h1>Free Medicare Course</h1>
      <p class="course-hero-sub">
        Six self-paced lessons covering everything you need to know before you enroll in
        Medicare — no account, no login, and no cost to take it.
      </p>
      <div class="course-hero-cta">
        <a href="#vl-grid" class="btn btn-primary">Start the Course</a>
        <a href="/guide" class="btn btn-outline">Prefer a written guide? Get it free by email &rarr;</a>
      </div>
    </div>
  </section>

  <section class="course-frame-section">
    <div class="frame-wrap">
      <iframe
        id="course-frame"
        src="https://course.learnmedicare.org"
        title="Learn Medicare free course"
        loading="lazy"
        allowfullscreen
      ></iframe>
    </div>
    <noscript>
      <p class="fallback-note">
        Course not loading? Watch directly at
        <a href="https://course.learnmedicare.org" target="_blank" rel="noopener noreferrer">course.learnmedicare.org &rarr;</a>
      </p>
    </noscript>
    <p class="fallback-note" id="fallback-note" hidden>
      Course not loading? Watch directly at
      <a href="https://course.learnmedicare.org" target="_blank" rel="noopener noreferrer">course.learnmedicare.org &rarr;</a>
    </p>
  </section>

  <section class="video-lessons-section">
    <div class="container">
      <h2>Video Lessons</h2>
      <p class="vl-intro">
        Watch each lesson below, then mark it complete. Once all six are done, your
        certificate of completion unlocks underneath.
      </p>
      <div class="vl-grid" id="vl-grid">
        {LESSONS.map((lesson) => (
          <div class="vl-card" data-lesson={lesson.n}>
            <div class="vl-card-head">
              <span class="vl-num">Lesson {lesson.n}</span>
              <span class="vl-check" aria-hidden="true">&#10003;</span>
            </div>
            <h3>{lesson.title}</h3>
            <div class="vl-video-wrap" data-video-wrap data-video-src={`/videos/lesson${lesson.n}.mp4`}>
              <video
                controls
                preload="none"
                width="100%"
                poster="/brand/psg-logo.png"
                data-lesson-video
                hidden
              >
                Your browser does not support embedded video. Watch at
                <a href={`/videos/lesson${lesson.n}.mp4`}>course.learnmedicare.org</a>.
              </video>
              <div class="vl-coming-soon" data-coming-soon>
                <span class="vl-coming-soon-icon" aria-hidden="true">&#9200;</span>
                <span>Coming Soon</span>
              </div>
            </div>
            <label class="vl-mark">
              <input type="checkbox" class="vl-checkbox" data-lesson-checkbox={lesson.n} />
              Mark lesson {lesson.n} complete
            </label>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="certificate-section" id="certificate-section" hidden>
    <div class="container">
      <h2>Your Certificate of Completion</h2>
      <p class="cert-name-prompt">
        <label for="cert-name-input">Name for your certificate:</label>
        <input type="text" id="cert-name-input" placeholder="Full name" autocomplete="name" />
      </p>
      <div class="certificate" id="certificate">
        <img class="cert-logo" src="/brand/psg-logo.png" alt="Price Services Group logo" />
        <p class="cert-eyebrow">Certificate of Completion</p>
        <h3 id="cert-name">Your Name</h3>
        <p class="cert-body">has successfully completed the free six-lesson Medicare course from</p>
        <p class="cert-brand">Learn Medicare, a Price Services Group resource</p>
        <p class="cert-date" id="cert-date"></p>
        <p class="cert-tagline">Where You Matter</p>
      </div>
      <button type="button" class="cert-print-btn" id="cert-print-btn">Print / Save as PDF</button>
    </div>
  </section>

  <section class="course-lead-section">
    <div class="container course-lead-inner">
      <h2>Get our free Medicare guide delivered to your inbox.</h2>
      <p class="course-lead-sub">One email. No spam. Unsubscribe anytime.</p>

      <form id="course-lead-form" class="lead-form" novalidate>
        <div class="form-row">
          <label for="course-firstName">First Name <span aria-hidden="true">*</span></label>
          <input type="text" id="course-firstName" name="firstName" autocomplete="given-name" required />
        </div>
        <div class="form-row">
          <label for="course-email">Email <span aria-hidden="true">*</span></label>
          <input type="email" id="course-email" name="email" autocomplete="email" required />
        </div>
        <!-- Honeypot — hidden from real visitors -->
        <div class="hp-field" aria-hidden="true">
          <label for="course-website">Website</label>
          <input type="text" id="course-website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <button type="submit" class="btn btn-primary form-submit">Send Me the Free Guide</button>
        <p id="course-form-error" class="form-error" role="alert" hidden></p>
      </form>

      <div id="course-form-success" class="form-success" hidden>
        <p>Your guide is on its way — check your inbox!</p>
      </div>
    </div>
  </section>
</MinimalLayout>

<script>
  const frame = document.getElementById('course-frame') as HTMLIFrameElement | null;
  const note = document.getElementById('fallback-note');
  if (frame && note) {
    const timer = setTimeout(() => {
      note.hidden = false;
    }, 3500);
    frame.addEventListener('load', () => {
      // Best-effort: if the iframe successfully reports a load event, assume it rendered.
      clearTimeout(timer);
    });
    frame.addEventListener('error', () => {
      note.hidden = false;
    });
  }
</script>

<script is:inline>
  (function () {
    // Probe each lesson's video file with a HEAD request before revealing the
    // <video> element. A missing file (404) shows a "Coming Soon" placeholder
    // instead of a broken/empty native video player.
    document.querySelectorAll('[data-video-wrap]').forEach(function (wrap) {
      var src = wrap.getAttribute('data-video-src');
      var video = wrap.querySelector('[data-lesson-video]');
      var comingSoon = wrap.querySelector('[data-coming-soon]');
      if (!src || !video || !comingSoon) return;

      fetch(src, { method: 'HEAD' })
        .then(function (res) {
          if (res.ok) {
            video.setAttribute('src', src);
            video.hidden = false;
            comingSoon.hidden = true;
          } else {
            comingSoon.hidden = false;
          }
        })
        .catch(function () {
          comingSoon.hidden = false;
        });
    });
  })();
</script>

<script is:inline>
  (function () {
    // Course video-lesson completion tracker (separate from the sitewide
    // /basics-/working-at-65 page-view tracker in LessonProgress.astro,
    // which tracks a different 5-page flow). Scoped to this page's 6
    // video lessons under its own sessionStorage key.
    var STORAGE_KEY = 'courseLessonsCompleted';
    var TOTAL_LESSONS = 6;

    function loadCompleted() {
      try {
        return JSON.parse(sessionStorage.getItem(STORAGE_KEY) || '{}');
      } catch (e) {
        return {};
      }
    }

    function saveCompleted(completed) {
      try {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify(completed));
      } catch (e) {}
    }

    function render() {
      var completed = loadCompleted();
      var checkboxes = document.querySelectorAll('[data-lesson-checkbox]');
      checkboxes.forEach(function (box) {
        var n = box.getAttribute('data-lesson-checkbox');
        box.checked = !!completed[n];
        var card = box.closest('.vl-card');
        if (card) {
          card.classList.toggle('vl-complete', !!completed[n]);
        }
      });

      var doneCount = Object.keys(completed).filter(function (k) {
        return completed[k];
      }).length;

      var certSection = document.getElementById('certificate-section');
      if (certSection) {
        certSection.hidden = doneCount < TOTAL_LESSONS;
      }
    }

    document.querySelectorAll('[data-lesson-checkbox]').forEach(function (box) {
      box.addEventListener('change', function () {
        var n = box.getAttribute('data-lesson-checkbox');
        var completed = loadCompleted();
        completed[n] = box.checked;
        saveCompleted(completed);
        render();
      });
    });

    var nameInput = document.getElementById('cert-name-input');
    var certName = document.getElementById('cert-name');
    var certDate = document.getElementById('cert-date');
    var NAME_KEY = 'courseCertName';

    if (nameInput && certName) {
      try {
        var savedName = sessionStorage.getItem(NAME_KEY);
        if (savedName) {
          nameInput.value = savedName;
          certName.textContent = savedName;
        }
      } catch (e) {}

      nameInput.addEventListener('input', function () {
        var val = nameInput.value.trim();
        certName.textContent = val || 'Your Name';
        try {
          sessionStorage.setItem(NAME_KEY, val);
        } catch (e) {}
      });
    }

    if (certDate) {
      certDate.textContent = new Date().toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
    }

    var printBtn = document.getElementById('cert-print-btn');
    if (printBtn) {
      printBtn.addEventListener('click', function () {
        window.print();
      });
    }

    render();
  })();
</script>

<script>
  const courseLeadForm = document.getElementById('course-lead-form') as HTMLFormElement | null;
  const courseLeadError = document.getElementById('course-form-error');
  const courseLeadSuccess = document.getElementById('course-form-success');

  courseLeadForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (courseLeadError) {
      courseLeadError.hidden = true;
      courseLeadError.textContent = '';
    }

    const formData = new FormData(courseLeadForm);
    const payload = {
      firstName: String(formData.get('firstName') ?? '').trim(),
      email: String(formData.get('email') ?? '').trim(),
      website: String(formData.get('website') ?? ''),
      pagePath: window.location.pathname,
    };

    const submitBtn = courseLeadForm.querySelector<HTMLButtonElement>('.form-submit');
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
    }

    try {
      const res = await fetch('/api/course-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json().catch(() => ({ ok: false }));

      if (res.ok && data.ok) {
        courseLeadForm.hidden = true;
        if (courseLeadSuccess) courseLeadSuccess.hidden = false;
      } else {
        throw new Error(data.error || 'Something went wrong. Please try again.');
      }
    } catch (err) {
      if (courseLeadError) {
        courseLeadError.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
        courseLeadError.hidden = false;
      }
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Me the Free Guide';
      }
    }
  });
</script>

<style>
  .course-hero {
    padding: 1.5rem 0 0.5rem;
    text-align: center;
  }
  .course-hero h1 { font-size: 1.6rem; margin: 0; }
  .course-hero-sub {
    max-width: 620px;
    margin: 0.6rem auto 0;
    color: var(--color-text-muted);
  }
  .course-hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1rem;
  }
  .course-frame-section {
    padding: 0 0 1.5rem;
  }
  .frame-wrap {
    width: 100%;
    height: calc(100vh - 130px);
    min-height: 500px;
  }
  .frame-wrap iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }
  .fallback-note {
    text-align: center;
    padding: 1rem 1.5rem 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .video-lessons-section {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }
  .video-lessons-section h2 {
    text-align: center;
    margin-bottom: 0.25rem;
  }
  .vl-intro {
    text-align: center;
    color: var(--color-text-muted);
    max-width: 640px;
    margin: 0 auto 1.5rem;
  }
  .vl-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .vl-card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem;
    background: var(--color-bg);
    transition: border-color 0.2s ease;
  }
  .vl-card.vl-complete {
    border-color: #51decc;
  }
  .vl-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.35rem;
  }
  .vl-num {
    font-size: 0.8rem;
    font-weight: 700;
    color: #9059B5;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .vl-check {
    color: #51decc;
    font-weight: 700;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .vl-card.vl-complete .vl-check {
    opacity: 1;
  }
  .vl-card h3 {
    margin: 0 0 0.6rem;
    font-size: 1.05rem;
  }
  .vl-card video {
    width: 100%;
    border-radius: 6px;
    background: #1a0a2e;
    display: block;
  }
  .vl-video-wrap {
    position: relative;
  }
  .vl-coming-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    aspect-ratio: 16 / 9;
    width: 100%;
    border-radius: 6px;
    background: var(--color-bg-alt);
    border: 1px dashed var(--color-border);
    color: var(--color-text-muted);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .vl-coming-soon-icon {
    font-size: 1.6rem;
  }
  .vl-mark {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    font-size: 0.9rem;
    cursor: pointer;
  }
  .vl-checkbox {
    width: 16px;
    height: 16px;
    accent-color: #51decc;
  }

  .certificate-section {
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--color-border);
  }
  .certificate-section h2 {
    text-align: center;
    margin-bottom: 1rem;
  }
  .cert-name-prompt {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .cert-name-prompt label {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.35rem;
  }
  .cert-name-prompt input {
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    font-size: 1rem;
    min-width: 260px;
  }
  .certificate {
    max-width: 640px;
    margin: 0 auto;
    background: #1a0a2e;
    color: #fff;
    border: 2px solid #9059B5;
    border-radius: 12px;
    padding: 2.5rem 2rem;
    text-align: center;
  }
  .cert-logo {
    height: 48px;
    margin-bottom: 1rem;
  }
  .cert-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8rem;
    color: #51decc;
    margin: 0 0 0.75rem;
  }
  .certificate h3 {
    font-size: 1.8rem;
    margin: 0 0 0.75rem;
    color: #EAD8F6;
  }
  .cert-body {
    margin: 0 0 0.25rem;
  }
  .cert-brand {
    font-weight: 700;
    margin: 0 0 1rem;
  }
  .cert-date {
    color: #EAD8F6;
    font-size: 0.9rem;
    margin: 0 0 1rem;
  }
  .cert-tagline {
    color: #51decc;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin: 0;
  }
  .cert-print-btn {
    display: block;
    margin: 1.5rem auto 0;
    padding: 0.6rem 1.5rem;
    border-radius: 999px;
    border: none;
    background: #9059B5;
    color: #fff;
    font-weight: 600;
    cursor: pointer;
  }
  .cert-print-btn:hover {
    background: #7a4a9c;
  }

  @media print {
    .course-hero,
    .course-frame-section,
    .video-lessons-section,
    .cert-name-prompt,
    .cert-print-btn,
    header,
    footer {
      display: none !important;
    }
    .certificate-section {
      border: none;
      padding: 0;
    }
    .course-lead-section {
      display: none !important;
    }
  }

  .course-lead-section {
    padding: 3rem 0 4rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-alt);
  }
  .course-lead-inner { max-width: 480px; margin: 0 auto; text-align: center; }
  .course-lead-sub { color: var(--color-text-muted); margin-bottom: 1.75rem; }
  .course-lead-inner .lead-form { text-align: left; }
  .course-lead-inner .form-row { margin-bottom: 1rem; }
  .course-lead-inner .form-row label { display: block; font-weight: 600; margin-bottom: 0.3rem; font-size: 0.9rem; }
  .course-lead-inner .form-row input {
    width: 100%;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 1rem;
  }
  .course-lead-inner .hp-field { position: absolute; left: -9999px; }
  .course-lead-inner .form-submit { width: 100%; margin-top: 0.5rem; }
  .course-lead-inner .form-error { color: #c0392b; margin-top: 0.75rem; font-size: 0.9rem; }
  .course-lead-inner .form-success p { font-weight: 600; }
</style>
