---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOKING_URL } from '../site.config';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Free Turning 65 Medicare Guide',
  description: 'Download a free guide covering everything you need to know about turning 65 and Medicare.',
};
const pdfPath = '/docs/T65-Medicare-Guide-2026.pdf';
---
<BaseLayout
  title="Free T65 Medicare Guide — Download Now | Learn Medicare"
  description="Download our free guide to turning 65 and Medicare: enrollment timing, coverage options, and how to avoid penalties."
  path="/guide"
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Free Guide</p>
      <h1>Your Free Turning 65 Medicare Guide</h1>
      <p class="subhead">
        A clear, no-pressure walkthrough of everything you need to know before you turn 65 —
        enrollment timing, coverage options, and how to avoid costly penalties.
      </p>
      <a href={pdfPath} class="btn btn-primary" download>Download the Free Guide</a>
    </div>
  </section>

  <section>
    <div class="container guide-grid">
      <div class="card">
        <h2>What's inside</h2>
        <ul>
          <li>A plain-English breakdown of Medicare Parts A, B, C, and D</li>
          <li>A timeline of enrollment periods, so you never miss a deadline</li>
          <li>An overview of Medicare Advantage vs. Medigap</li>
          <li>How to avoid late enrollment penalties</li>
          <li>Tips for coordinating Medicare with employer coverage</li>
        </ul>
        <p class="fine-print">
          This guide is educational and does not recommend any specific insurance plan.
        </p>
      </div>
      <div class="preview-card">
        <p class="eyebrow">Preview</p>
        <div class="pdf-frame-wrap">
          <iframe
            src={`${pdfPath}#view=FitH`}
            title="T65 Medicare Guide preview"
            loading="lazy"
          ></iframe>
        </div>
        <a href={pdfPath} class="btn btn-outline" download>Download PDF</a>
      </div>
    </div>
  </section>

  <section class="section-alt cta-band">
    <div class="container cta-inner">
      <h2>Want to talk it through?</h2>
      <p>Schedule a free, no-pressure review with a licensed independent advisor.</p>
      <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="btn btn-teal">Schedule Free Review</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { background: var(--color-lavender); padding: 4rem 0; }
  :root[data-theme="dark"] .page-hero { background: var(--color-bg-alt); }
  .subhead { color: var(--color-text-muted); font-size: 1.1rem; max-width: 640px; margin-bottom: 1.75rem; }
  .guide-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  .guide-grid ul { padding-left: 1.2rem; margin-bottom: 1.5rem; }
  .guide-grid li { margin-bottom: 0.5rem; }
  .fine-print { color: var(--color-text-muted); font-size: 0.85rem; margin: 0; }
  .preview-card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.5rem;
    text-align: center;
  }
  .pdf-frame-wrap {
    width: 100%;
    height: 420px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    margin: 0.75rem 0 1.25rem;
  }
  .pdf-frame-wrap iframe { width: 100%; height: 100%; border: none; }
  @media (max-width: 800px) {
    .guide-grid { grid-template-columns: 1fr; }
  }
  .cta-band { text-align: center; }
  .cta-inner p { color: var(--color-text-muted); margin-bottom: 1.5rem; }
</style>
