---
import BaseLayout from '../layouts/BaseLayout.astro';
import { COMPLIANCE } from '../site.config';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Terms of Use',
  url: 'https://learnmedicare.org/terms',
};
---
<BaseLayout
  title="Terms of Use | Learn Medicare"
  description="Terms governing your use of the Learn Medicare educational website."
  path="/terms"
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Legal</p>
      <h1>Terms of Use</h1>
      <p class="subhead">Effective Date: July 14, 2026</p>
    </div>
  </section>

  <section>
    <div class="container legal">
      <p>
        These Terms of Use ("Terms") govern your access to and use of learnmedicare.org (the
        "Site"), operated in connection with Kayla Price, a licensed insurance agent (NPN
        18530055), and Price Services Group LLC. By accessing or using the Site, you agree to be
        bound by these Terms. If you do not agree, please do not use the Site.

      </p>

      <h2>1. Educational Purpose Only</h2>
      <p>
        The Site is provided solely for general educational purposes about Medicare. Content on
        this Site — including lessons, articles, guides, calculators, and any other materials —
        is intended to help you understand Medicare concepts in plain language. Nothing on this
        Site constitutes a recommendation, endorsement, or solicitation to enroll in, disenroll
        from, or change any specific Medicare plan, product, or carrier. Coverage decisions
        should be made only after speaking with a licensed agent or reviewing official plan
        documents relevant to your individual circumstances.
      </p>

      <h2>2. Licensed Insurance Agent Disclosure</h2>
      <p>
        Kayla Price is a licensed insurance agent (NPN 18530055) authorized to discuss and sell
        Medicare-related insurance products in the states listed on this Site. {COMPLIANCE.tpmo}
        Any personalized plan discussion that may follow your use of this Site's educational
        content will be conducted separately, by a licensed agent, and is not part of the
        educational content itself.
      </p>

      <h2>3. No Guarantee of Accuracy</h2>
      <p>
        Medicare rules, costs, and plan availability change frequently. While we strive to keep
        this Site accurate and current, we make no warranty, express or implied, that any
        information on the Site is complete, accurate, or up to date. Always confirm details
        with <a href="https://www.medicare.gov" target="_blank" rel="noopener noreferrer">Medicare.gov</a>,
        1-800-MEDICARE, the <a href="https://www.ssa.gov" target="_blank" rel="noopener noreferrer">Social Security Administration (ssa.gov)</a>,
        or a licensed agent before making a coverage decision.
      </p>

      <h2>4. Not Affiliated with the Federal Government</h2>
      <p>
        This Site is not connected with or endorsed by the United States government or the
        federal Medicare program. "Medicare" is a federal program; we provide independent
        educational content about it.
      </p>

      <h2>5. Use of the Site</h2>
      <p>
        You agree to use the Site only for lawful purposes and in a manner consistent with these
        Terms. You may not: (a) copy, reproduce, or redistribute Site content for commercial
        purposes without our written permission; (b) attempt to interfere with the Site's normal
        operation; or (c) submit false or misleading information through any form on the Site.
      </p>

      <h2>6. Intellectual Property</h2>
      <p>
        All content on the Site, including text, graphics, logos, and course materials, is owned
        by or licensed to Price Services Group LLC and is protected by applicable intellectual
        property laws. You may view and share Site content for personal, non-commercial,
        educational use only.
      </p>

      <h2>7. Third-Party Links</h2>
      <p>
        The Site may link to third-party websites, including
        <a href="https://www.medicare.gov" target="_blank" rel="noopener noreferrer">Medicare.gov</a>,
        <a href="https://www.ssa.gov" target="_blank" rel="noopener noreferrer">ssa.gov</a>, and
        insurance carrier sites, for your convenience. We do not control and are not responsible
        for the content or practices of third-party sites.
      </p>

      <h2>8. Limitation of Liability</h2>
      <p>
        To the fullest extent permitted by law, Price Services Group LLC and Kayla Price shall
        not be liable for any direct, indirect, incidental, or consequential damages arising out
        of your use of, or inability to use, the Site or its content, including any decisions
        made based on information found on the Site.
      </p>

      <h2>9. Communications Consent</h2>
      <p>
        By submitting a form on this Site, you consent to be contacted as described in our{' '}
        <a href="/privacy">Privacy Policy</a>, including by phone, text, and email, regarding
        Medicare education and related services.
      </p>

      <h2>10. Changes to These Terms</h2>
      <p>
        We may revise these Terms from time to time. The "Effective Date" above reflects the
        most recent revision. Continued use of the Site after changes are posted constitutes
        acceptance of the revised Terms.
      </p>

      <h2>11. Governing Law</h2>
      <p>
        These Terms are governed by the laws of the State of North Carolina, without regard to
        its conflict of law principles.
      </p>

      <h2>12. Contact Us</h2>
      <p>
        Questions about these Terms may be directed to Kayla Price, licensed insurance agent
        (NPN 18530055), Price Services Group LLC, through the contact options listed on this
        Site.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-dark) 0%, #2b1147 100%);
    color: #fff;
    padding: 4rem 0;
  }
  .hero h1 { color: #fff; }
  .hero .eyebrow { color: var(--color-teal); }
  .subhead { color: #e2d4f0; }
  .legal { max-width: 800px; }
  .legal h2 { margin-top: 2rem; font-size: 1.3rem; }
  .legal p, .legal li { color: var(--color-text-muted); line-height: 1.7; }
  .legal ul { padding-left: 1.4rem; }
</style>
