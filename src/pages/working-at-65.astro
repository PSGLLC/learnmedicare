---
import BaseLayout from '../layouts/BaseLayout.astro';
import MarkCompleteButton from '../components/MarkCompleteButton.astro';
import { authorship, dataset } from '../lib/schema';

const DATE_PUBLISHED = '2026-07-23';
const DATE_MODIFIED = '2026-07-24';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Medicare and Working at 65',
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.quick-answer'],
    },
    ...authorship(DATE_PUBLISHED, DATE_MODIFIED),
  },
  dataset({
    name: 'Medicare Special Enrollment Period & Creditable Coverage Rules',
    description: 'Official CMS/SSA rules on delaying Medicare with employer group coverage and the Special Enrollment Period for people working past 65.',
    creatorUrl: 'https://www.ssa.gov/benefits/medicare/',
  }),
  {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  author: { '@type': 'Person', name: 'Kayla Price', url: 'https://priceservicesgroup.com' },
  mainEntity: [
    {
      '@type': 'Question',
      name: "Can I delay Medicare if I'm still working at 65?",
      acceptedAnswer: { '@type': 'Answer', text: 'In many cases, yes — especially if your employer has 20 or more employees and offers group health coverage. You may be able to delay Part B without a penalty as long as that coverage is creditable.' },
    },
    {
      '@type': 'Question',
      name: 'What is "creditable coverage"?',
      acceptedAnswer: { '@type': 'Answer', text: 'Creditable coverage is health or drug coverage that\'s considered at least as good as Medicare\'s. Having creditable coverage can let you delay Medicare enrollment without facing a late enrollment penalty later.' },
    },
    {
      '@type': 'Question',
      name: 'Do I need to enroll in Medicare if I still have employer coverage?',
      acceptedAnswer: { '@type': 'Answer', text: 'Not necessarily. If your employer has 20 or more employees and your group coverage is creditable, you can often delay enrolling without penalty. If your employer has fewer than 20 employees, Medicare typically becomes primary, so enrolling on time usually matters more.' },
    },
    {
      '@type': 'Question',
      name: 'What happens when I eventually leave my job or lose employer coverage?',
      acceptedAnswer: { '@type': 'Answer', text: 'Losing employer group coverage generally triggers a Special Enrollment Period, giving you a window to sign up for Medicare without facing a late enrollment penalty, as long as your prior coverage was creditable.' },
    },
    ],
  },
];
---
<BaseLayout
  title="Medicare and Working at 65: Employer Coverage Explained | Learn Medicare"
  description="How Medicare interacts with employer coverage after 65, when it may make sense to delay Part B, and what creditable coverage means."
  path="/working-at-65/"
  breadcrumbs={[{ name: 'Working at 65', url: '/working-at-65/' }]}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Working at 65</p>
      <h1>Still working at 65? Here's how Medicare fits in.</h1>
      <p class="subhead">Turning 65 doesn't always mean you need to enroll in Medicare right away — but the right choice depends on your employer coverage.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="quick-answer">
        <p class="quick-answer-label">Quick Answer</p>
        <p>
          If you or your spouse has employer coverage from a company with 20 or more employees,
          you can delay Medicare without penalty. You have a Special Enrollment Period of 8 months
          after that coverage ends to enroll in Medicare Part B without a late penalty.
        </p>
      </div>

      <div class="grid grid-2">
        <div class="card">
          <h2>Employer size matters</h2>
          <p>
            A common rule of thumb: if your employer has <strong>20 or more employees</strong> and
            you have group health coverage through that employer (or a spouse's employer), you
            generally have the option to delay Medicare Part B without a late enrollment penalty,
            since you'd qualify for a <a href="/enrollment">Special Enrollment Period</a> later.
          </p>
          <p>
            If your employer has fewer than 20 employees, Medicare often becomes the primary payer,
            and delaying enrollment can leave gaps in coverage — this is a conversation worth having
            with your HR department and a licensed insurance agent.
          </p>
        </div>
        <div class="card">
          <h2>What is "creditable coverage"?</h2>
          <p>
            Creditable coverage is health or drug coverage that Medicare considers at least as good
            as its own. If your employer coverage is creditable, you can generally delay Medicare
            enrollment without facing a late enrollment penalty when you eventually sign up.
          </p>
          <p>
            Ask your employer's benefits administrator for a "creditable coverage" notice each year —
            it confirms whether your plan meets this standard for both medical (Part B) and
            prescription drug (Part D) purposes. If you're weighing employer coverage against
            Medicare options, see how <a href="/coverage">Medicare Advantage compares to Medigap</a>.
          </p>
        </div>
      </div>

      <div class="callout" style="margin-top: 2.5rem;">
        <p style="margin:0;">
          <strong>Why this matters:</strong> if your coverage isn't creditable, or you let it lapse
          without enrolling in Medicare, you could face the late enrollment penalties described on
          our <a href="/penalties">Penalties</a> page. Confirming creditable coverage status before
          you decide to delay is one of the most important steps in planning your Medicare timeline. For
          official guidance, see <a href="https://www.medicare.gov" target="_blank" rel="noopener noreferrer">Medicare.gov</a>
          or the <a href="https://www.ssa.gov/benefits/medicare/" target="_blank" rel="noopener noreferrer">Social Security Administration</a>.
        </p>
      </div>
    </div>
  </section>

  <p style="text-align:center;color:var(--color-text-muted);font-size:.95rem;max-width:640px;margin:0 auto 2rem;">
    Weighing Medicare against employer coverage? <a href="https://partner.priceservicesgroup.com/quiz">Take the Medicare Decision Style Quiz</a> or
    <a href="https://priceservicesgroup.com/contact">schedule a consultation with a Medicare advisor</a>.
  </p>

  <MarkCompleteButton slug="working-at-65" />

  <section class="section-alt cta-band">
    <div class="container cta-inner">
      <h2>Grab our free Turning 65 guide</h2>
      <p>A step-by-step reference for navigating your Medicare decisions.</p>
      <a href="/guide" class="btn btn-primary">Get the Free Guide</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { background: var(--color-lavender); padding: 4rem 0; }
  :root[data-theme="dark"] .page-hero { background: var(--color-bg-alt); }
  .subhead { color: var(--color-text-muted); font-size: 1.1rem; max-width: 680px; }
  .cta-band { text-align: center; }
  .cta-inner p { color: var(--color-text-muted); margin-bottom: 1.5rem; }

  .quick-answer {
    border-left: 4px solid var(--color-purple);
    background: var(--color-lavender);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }
  :root[data-theme="dark"] .quick-answer {
    background: rgba(144, 89, 181, 0.1);
  }
  .quick-answer-label {
    margin: 0 0 0.4rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-purple);
  }
  .quick-answer p:last-child { margin: 0; }
</style>
