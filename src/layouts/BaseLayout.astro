---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyGuideCTA from '../components/StickyGuideCTA.astro';
import LessonProgress from '../components/LessonProgress.astro';
import CourseProgressBar from '../components/CourseProgressBar.astro';
import '../styles/global.css';
import { SITE_URL } from '../site.config';

interface Breadcrumb {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  path: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  ogImage?: string;
  breadcrumbs?: Breadcrumb[];
}

const { title, description, path, jsonLd, ogImage = '/brand/psg-logo.png', breadcrumbs } = Astro.props;
const canonical = new URL(path, SITE_URL).toString();
const ogImageUrl = new URL(ogImage, SITE_URL).toString();
const jsonLdEntries = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];

if (breadcrumbs && breadcrumbs.length > 0) {
  const crumbList = [{ name: 'Home', url: '/' }, ...breadcrumbs];
  jsonLdEntries.push({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: crumbList.map((crumb, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: crumb.name,
      item: new URL(crumb.url, SITE_URL).toString(),
    })),
  });
}
const normalizedPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const showStickyGuideCTA = normalizedPath !== '/guide';
const LESSON_PATHS = ['/basics', '/enrollment', '/coverage', '/penalties', '/working-at-65'];
const showLessonProgress = LESSON_PATHS.includes(normalizedPath);
// Feature 8 (Course Progress Tracking) — slug used as the localStorage key
// for the current lesson page; drives CourseProgressBar + the footer's
// "Reset Progress" link on the same 5 pages.
const currentLessonSlug = normalizedPath.replace(/^\//, '');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/brand/psg-logo.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {jsonLdEntries.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}

    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      (function () {
        try {
          navigator.modelContext = {
            tools: [
              {
                name: 'medicare_quiz',
                description: 'Medicare Decision Style Quiz — helps users identify their Medicare decision style',
                endpoint: '/.well-known/mcp.json',
              },
              {
                name: 'medicare_enrollment_info',
                description: 'Get Medicare enrollment period information and deadlines',
                endpoint: '/.well-known/mcp.json',
              },
            ],
          };
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Nav />
    {showLessonProgress && <LessonProgress />}
    {showLessonProgress && <CourseProgressBar slug={currentLessonSlug} />}
    <main>
      <slot />
    </main>
    <Footer showResetProgress={showLessonProgress} />
    {showStickyGuideCTA && <StickyGuideCTA />}
    <script src="https://partner.priceservicesgroup.com/psg-tracker.js" defer></script>
  </body>
</html>
