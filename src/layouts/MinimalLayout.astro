---
import MinimalCompliance from '../components/MinimalCompliance.astro';
import '../styles/global.css';
import { SITE_URL } from '../site.config';

interface Breadcrumb {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  path: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  breadcrumbs?: Breadcrumb[];
  ogImage?: string;
}
const {
  title,
  description,
  path,
  jsonLd,
  breadcrumbs,
  // Real file, not a placeholder — public/brand/psg-logo.png is 2048x1035px,
  // already well over the 1200x630 og:image floor. No dedicated course
  // thumbnail exists in the repo, so this is the best available image
  // (same default BaseLayout.astro uses on the rest of the site).
  ogImage = '/brand/psg-logo.png',
} = Astro.props;
const canonical = new URL(path, SITE_URL).toString();
const ogImageUrl = new URL(ogImage, SITE_URL).toString();
const jsonLdEntries = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];

if (breadcrumbs && breadcrumbs.length > 0) {
  const crumbList = [{ name: 'Home', url: '/' }, ...breadcrumbs];
  jsonLdEntries.push({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: crumbList.map((crumb, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: crumb.name,
      item: new URL(crumb.url, SITE_URL).toString(),
    })),
  });
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/brand/psg-logo.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="2048" />
    <meta property="og:image:height" content="1035" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {jsonLdEntries.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      (function () {
        try {
          navigator.modelContext = {
            tools: [
              {
                name: 'medicare_quiz',
                description: 'Medicare Decision Style Quiz — helps users identify their Medicare decision style',
                endpoint: '/.well-known/mcp.json',
              },
              {
                name: 'medicare_enrollment_info',
                description: 'Get Medicare enrollment period information and deadlines',
                endpoint: '/.well-known/mcp.json',
              },
            ],
          };
        } catch (e) {}
      })();
    </script>
    <script src="https://t.contentsquare.net/uxa/ebc86a8183b9c.js" defer></script>
  </head>
  <body>
    <header class="mini-header">
      <div class="container mini-header-inner">
        <a href="/" class="mini-brand">
          <img src="/brand/psg-logo.png" alt="Price Services Group logo" />
          <span>Learn Medicare</span>
        </a>
        <a href="/" class="back-link">&larr; Back to Learn Medicare</a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <MinimalCompliance />
  </body>
</html>

<style>
  .mini-header {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .mini-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 0;
  }
  .mini-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-text);
    font-family: var(--font-heading);
    font-weight: 700;
  }
  .mini-brand img { height: 34px; }
  .back-link { font-size: 0.9rem; font-weight: 600; text-decoration: none; }
</style>
